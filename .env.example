# Copiá este archivo a .env y completá los valores.
# cp .env.example .env   (o Copy-Item .env.example .env en PowerShell)
#
# Ningún valor de acá está seteado — son todos placeholders. Las instrucciones
# de cada bloque explican cómo generarlo u obtenerlo.

# -----------------------------------------------------------------------------
# Base de datos (Postgres, vía docker-compose.yml)
# -----------------------------------------------------------------------------

# Contraseña del usuario "visitalo" en Postgres. Generarla con:
#   openssl rand -hex 24
# (en PowerShell: -join ((48..57)+(97..122)|Get-Random -Count 32|%{[char]$_}))
DB_PASSWORD=

# Cadena de conexión completa que usa la app (Drizzle). Tiene que usar el
# mismo valor que pusiste en DB_PASSWORD. Si corrés docker-compose en local,
# el host es "localhost" y el puerto el que quedó mapeado en docker-compose.yml
# (5433 por defecto, no 5432 — evita chocar con un Postgres nativo de Windows
# si lo tenés instalado; ver el comentario en docker-compose.yml).
DATABASE_URL=postgres://visitalo:CAMBIAR_POR_DB_PASSWORD@localhost:5433/visitalo

# -----------------------------------------------------------------------------
# MinIO (API compatible S3 — el contenedor queda levantado para dev local,
# pero la app en producción NO lo usa todavía: las fotos de propuestas se
# suben a Vercel Blob, ver más abajo. MinIO queda listo para el día que se
# migre a self-host — ver el comentario en src/lib/storage.ts.)
# -----------------------------------------------------------------------------

# Usuario y contraseña root de la consola de MinIO (http://localhost:9001).
# Generar igual que DB_PASSWORD:
#   openssl rand -hex 12   (usuario)
#   openssl rand -hex 24   (contraseña)
MINIO_USER=
MINIO_PASSWORD=

# -----------------------------------------------------------------------------
# Vercel Blob (storage de fotos de propuestas en producción)
# -----------------------------------------------------------------------------

# Se genera solo al crear un Blob Store en el dashboard de Vercel (Storage >
# Create Database > Blob) y conectarlo al proyecto — Vercel lo agrega a las
# env vars automáticamente, no hace falta generarlo a mano. En local, sin
# este valor, la subida de fotos falla silenciosamente y las propuestas
# quedan sin fotos (no rompe nada más).
BLOB_READ_WRITE_TOKEN=

# -----------------------------------------------------------------------------
# Anthropic (parseo/normalización/redacción — se usa desde la Fase 2/3, no
# hace falta todavía para levantar el webhook ni los jobs)
# -----------------------------------------------------------------------------

# Se obtiene creando una API key en https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# WhatsApp Cloud API (Meta) — NO hace falta para probar el webhook en local.
# El webhook funciona igual sin estos valores: el envío de mensajes queda
# simulado (se loguea en consola en vez de llamar a la Graph API real).
# Completar cuando se dé de alta la cuenta de WhatsApp Business API
# (Meta Business Manager) — ver sección 11 del spec.
# -----------------------------------------------------------------------------

# String arbitrario que vos elegís (no lo da Meta). Se configura también del
# lado de Meta al suscribir el webhook — tienen que coincidir. Generar con:
#   openssl rand -hex 16
WHATSAPP_VERIFY_TOKEN=

# Token de acceso permanente de la app de WhatsApp Business en Meta Business
# Manager (Configuración de la app > WhatsApp > API Setup).
WHATSAPP_TOKEN=

# Phone Number ID (no es el número de teléfono) que aparece en la misma
# pantalla de API Setup de Meta Business Manager.
WHATSAPP_PHONE_NUMBER_ID=

# Versión de la Graph API a usar. Opcional: si no se setea, el código usa
# v21.0 por defecto.
WHATSAPP_API_VERSION=v21.0

# -----------------------------------------------------------------------------
# Jobs (/api/jobs/run)
# -----------------------------------------------------------------------------

# Secreto compartido para que solo el scheduler (o vos a mano) pueda disparar
# el procesamiento de jobs. Generar con:
#   openssl rand -hex 24
CRON_SECRET=

# -----------------------------------------------------------------------------
# Admin (/admin) — un solo usuario operador, sin registro público.
# -----------------------------------------------------------------------------

# Clave para firmar la cookie de sesión del admin. Generar con:
#   openssl rand -base64 32
SESSION_SECRET=

# Tu email — es lo que vas a escribir en el login de /admin.
ADMIN_EMAIL=

# Hash de tu contraseña (NO la contraseña en texto plano). Se genera así,
# una vez que tengas `npm install` corrido:
#   npm run admin:hash-password -- "tu-contraseña"
# Copiá la salida completa (formato "salt:hash") acá.
ADMIN_PASSWORD_HASH=

# -----------------------------------------------------------------------------
# URL pública de la app
# -----------------------------------------------------------------------------

# Se usa para armar los links de la shortlist que el bot manda por WhatsApp
# (ej. "Mirá tu shortlist acá: $APP_URL/s/<token>"). En local dejala vacía —
# el código usa "http://localhost:3000" por defecto. En Vercel (u otro
# hosting) SÍ hay que setearla, con el dominio real, sin barra al final
# (ej. https://visitalo.vercel.app o https://visitalo.com.ar cuando esté
# el dominio propio) — si no, los links que reciben los compradores van a
# apuntar a localhost y no van a funcionar.
APP_URL=
